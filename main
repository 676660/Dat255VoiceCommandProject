import tensorflow as tf
import tensorflow_datasets as tfds
import numpy as np
import matplotlib.pyplot as plt
from sklearn.metrics import classification_report
from collections import Counter
from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay
import seaborn as sns                    
import librosa                          
import librosa.display                  
import IPython.display as ipd  
from collections import Counter
from sklearn.metrics import roc_curve, auc, confusion_matrix, classification_report
from sklearn.preprocessing import label_binarize
import time


AUTOTUNE = tf.data.AUTOTUNE
#Uploading the dataset from tensorflow dataset that gives us (label,audio)
(train_ds_raw, val_ds_raw, test_ds_raw), ds_info = tfds.load(
    "speech_commands",
    split=["train", "validation", "test"],
    as_supervised=True,
    with_info=True,
)
ds_info = tfds.builder("speech_commands").info



#All the lables in the dataset
label_names = ds_info.features["label"].names
print(label_names)

#We need only the commands that we need for our snake game + unknown and silence
chosen_commands = sorted(['down', 'up', 'left', 'right', '_silence_', '_unknown_'])
num_labels   = len(chosen_commands)
#We give them new ids becasue they are already numerical  and have numbers from 0 to 11
#so they get new ids from 0 to 5
commands_ids = [label_names.index(w) for w in chosen_commands]
id_remap     = {orig: new for new, orig in enumerate(commands_ids)}
wanted_ids_tf = tf.constant(commands_ids, dtype=tf.int64)


#Making the function for the filter so only commands that we have choosen will be in the dataset
def filter_commands(audio, label):
    return tf.reduce_any(tf.equal(label, wanted_ids_tf))
#Making the function for the remapping so classes get new ids
def remap_label(audio, label):
    original_label = tf.cast(label, tf.int64)
    new_label = original_label
    for orig, new in id_remap.items():
        new_label = tf.where(
            tf.equal(original_label, tf.cast(orig, tf.int64)),
            tf.cast(new, tf.int64),
            new_label
        )
    return audio, tf.cast(new_label, tf.int32)

#Appplying the filtering and remapping functions to all datasets
train_ds = train_ds_raw.filter(filter_commands).map(remap_label)
val_ds   = val_ds_raw.filter(filter_commands).map(remap_label)
test_ds  = test_ds_raw.filter(filter_commands).map(remap_label)





#We need to do augumnetion and see this combination gives us the best result with having 75% clean 
# training data and 25% augmented training data
split = int(66880  * 0.25)  
train_clean     = train_ds.take(split)
train_augmented = train_ds.skip(split)

#Making a function for converting and normlizing audio samples
#making the type to float32 and making the scale of audio to be between -1 and 1
#we also pad and trim any audios over 1 second or under one second
def preprocess(audio, label):
    audio = tf.squeeze(tf.cast(audio, tf.float32)) / 32768.0
    audio = audio[:16000]
    audio = tf.pad(audio, [[0, tf.maximum(0, 16000 - tf.shape(audio)[0])]])
    return audio, label
#Making a function for augumneting the audio   
def preprocess_augmented(audio, label):
    audio, label = preprocess(audio, label)
    
    #Background noise
    noise_level = tf.random.uniform((), 0.001, 0.015)
    audio = audio + tf.random.normal(tf.shape(audio), stddev=noise_level)
    
    #Gain 
    gain = tf.random.uniform((), 0.6, 1.4)
    audio = tf.clip_by_value(audio * gain, -1.0, 1.0)
    
    #Time shift 
    shift = tf.random.uniform((), -1600, 1600, dtype=tf.int32)
    audio = tf.cond(shift > 0,
        lambda: tf.concat([tf.zeros([shift]), audio[:-shift]], axis=0),
        lambda: tf.concat([audio[-shift:], tf.zeros([-shift])], axis=0))
    
    return audio, label

#Applying the function (we make a clean and augumneted version of training data)
train_ds_pros_clean=train_clean.map(preprocess , num_parallel_calls=AUTOTUNE)
train_ds_pros_aug=train_augmented.map(preprocess_augmented , num_parallel_calls=AUTOTUNE)
val_ds_pros=val_ds.map(preprocess, num_parallel_calls=AUTOTUNE)
test_ds_pros=test_ds.map(preprocess, num_parallel_calls=AUTOTUNE)



#Making a function that first turns audio waves to spectrgram and then to mel spectrgram
#(This was inspired by tensorflow auido torturail:https://www.tensorflow.org/tutorials/audio/simple_audio)
def make_spectrogram(audio, label):
    
    s = tf.signal.stft(audio, frame_length=256, frame_step=128)
    s = tf.abs(s)
    
    num_spectrogram_bins = s.shape[-1]
    linear_to_mel = tf.signal.linear_to_mel_weight_matrix(
        num_mel_bins=64,
        num_spectrogram_bins=num_spectrogram_bins,
        sample_rate=16000,
        lower_edge_hertz=20.0,
        upper_edge_hertz=8000.0
    )
    mel = tf.tensordot(s, linear_to_mel, 1)
    mel = tf.math.log(mel + 1e-6)
    mel = mel[..., tf.newaxis]
    return tf.ensure_shape(mel, [124, 64, 1]), label

#Augumneting the spectrogram with frequncy masking and timemasking
#(This was inspired by Voice Command Google V1 :https://www.kaggle.com/code/firmanik/voice-command-google-v1)
def spec_augment(spectrogram, label):
    s = spectrogram
    freq_mask  = tf.random.uniform((), 0, 10, dtype=tf.int32)
    freq_start = tf.random.uniform((), 0, 64 - freq_mask, dtype=tf.int32)
    s = s * tf.concat([tf.ones([124, freq_start, 1]),
                       tf.zeros([124, freq_mask, 1]),
                       tf.ones([124, 64 - freq_start - freq_mask, 1])], axis=1)
    time_mask  = tf.random.uniform((), 0, 10, dtype=tf.int32)
    time_start = tf.random.uniform((), 0, 124 - time_mask, dtype=tf.int32)
    s = s * tf.concat([tf.ones([time_start, 64, 1]),
                       tf.zeros([time_mask, 64, 1]),
                       tf.ones([124 - time_start - time_mask, 64, 1])], axis=0)
    return s, label

#Applying augumnetions functions(we make a clean and augumneted version of training data)
train_ds_spec_clean = train_ds_pros_clean.map(make_spectrogram, num_parallel_calls=AUTOTUNE)
train_ds_spec_aug = train_ds_pros_aug.map(make_spectrogram, num_parallel_calls=AUTOTUNE).map(spec_augment, num_parallel_calls=AUTOTUNE)
#then. we mix both togther 
train_ds_spec = train_ds_spec_clean.concatenate(train_ds_spec_aug)
val_ds_spec   = val_ds_pros.map(make_spectrogram, num_parallel_calls=AUTOTUNE)
test_ds_spec  = test_ds_pros.map(make_spectrogram, num_parallel_calls=AUTOTUNE)




#Now we start batching so we can start training our model
train_ds_batched = train_ds_spec.repeat().shuffle(5000, seed=42).batch(64).prefetch(AUTOTUNE)
val_ds_batched   = val_ds_spec.batch(64).prefetch(AUTOTUNE)
test_ds_batched  = test_ds_spec.batch(64).prefetch(AUTOTUNE)




#We inspect our datasets and see there is a big unblance between unknown and other
#classes ,if a model has so much more of a class it will learn to always predict that
#class because its going to be right most of the time and therefor we calculate class 
#weights from TRAIN counts to make the bigger class less important and smaller class more important


#Finding the weight of each class in trainingset based on how many samples they have from totall samples 
#( This was inspired by compute_class_weight in scikit-learn:https://scikit-learn.org/stable/modules/generated/sklearn.utils.class_weight.compute_class_weight.html)
train_counts = {
    0: 668,    # _silence_
    1: 54074,  # _unknown_
    2: 3134,   # down
    3: 3037,   # left
    4: 3019,   # right
    5: 2948,   # up
}

total_train = sum(train_counts.values())
class_weight = {
    i: total_train / (len(chosen_commands) * train_counts[i])
    for i in range(len(chosen_commands))
}




#Making the normalization layer that we will apply in the model
normal_layer = tf.keras.layers.Normalization()
normal_layer.adapt(
    val_ds_raw.filter(filter_commands).map(remap_label)
    .map(preprocess, num_parallel_calls=AUTOTUNE)
    .map(make_spectrogram, num_parallel_calls=AUTOTUNE)
    .map(lambda s, l: s)
)

#Building our CNN model 
#(This was inspired by Simple audio recognition :https://www.tensorflow.org/tutorials/audio/simple_audio)
model = tf.keras.Sequential([
    tf.keras.layers.Input(shape=(124, 64, 1)),
    tf.keras.layers.Resizing(32, 32),
    normal_layer,
    tf.keras.layers.Conv2D(32, 3, activation='relu'),                   
    tf.keras.layers.Conv2D(64, 3, activation='relu'),     
    tf.keras.layers.Conv2D(128, 3, activation='relu'),
    tf.keras.layers.MaxPooling2D(), 
    tf.keras.layers.Dropout(0.2),
    tf.keras.layers.Flatten(),                        
    tf.keras.layers.Dense(258, activation='relu'),
    tf.keras.layers.Dropout(0.3),
    tf.keras.layers.Dense(num_labels),
])
model.summary()

#Using the learning rate that gives us the best results and loss and metric that works for us
model.compile(
    optimizer=tf.keras.optimizers.Adam(learning_rate=0.0005),
    loss=tf.keras.losses.SparseCategoricalCrossentropy(from_logits=True),
    metrics=['accuracy'],
)

#Fitting our model with 30 epochs, using class weight and  steps per epoch becasue 
#we use repeat() so it knows that after 1143 batches one epoch is done
#We laso use 3 callabcks:
#first we use early stopping which chekcs if validation loss does not improve after 3 it stops
#next call abck is reduceLRonplateau which says if If val_loss doesn't improve for 2 epochs → multiply learning rate by 0.5
#and last we use modekcheckpoint to save the best model that has the best validation accuracy
history = model.fit(
    train_ds_batched,
    epochs=30,
    steps_per_epoch=1143,
    validation_data=val_ds_batched,
    class_weight=class_weight,      
    callbacks=[
        tf.keras.callbacks.EarlyStopping(patience=3, restore_best_weights=True, verbose=1),
        tf.keras.callbacks.ReduceLROnPlateau(patience=2, factor=0.5, verbose=1),
        tf.keras.callbacks.ModelCheckpoint(filepath='best_model4.keras', monitor='val_accuracy',save_best_only=True, mode='max',verbose=1)
    ],
)
#Saving the best model
best_model = tf.keras.models.load_model('best_model.keras')
print("Best model loaded!")





#Evaluating test set 
test_loss, test_accuracy = model.evaluate(test_ds_batched, verbose=0)
print(f'Test Loss:     {test_loss:.4f}')
print(f'Test Accuracy: {test_accuracy:.4f}')


#Test set per class results
y_true_test = []
y_pred_test = []
y_probs_test = []
for specs, labels in test_ds_batched:
    probs = tf.nn.softmax(model(specs, training=False))
    y_probs_test.extend(probs.numpy())
    y_pred_test.extend(np.argmax(probs.numpy(), axis=1))
    y_true_test.extend(labels.numpy())
y_true_test = np.array(y_true_test)
y_pred_test = np.array(y_pred_test)
y_probs_test = np.array(y_probs_test)
print(classification_report(y_true_test, y_pred_test, target_names=chosen_commands))


#Test set confusion matrix
cm = confusion_matrix(y_true_test, y_pred_test)
plt.figure(figsize=(10, 8))
plt.imshow(cm, cmap='Blues')
plt.title('Confusion Matrix — Test Set')
plt.xlabel('Predicted')
plt.ylabel('True')
plt.xticks(range(len(chosen_commands)), chosen_commands, rotation=45)
plt.yticks(range(len(chosen_commands)), chosen_commands)
plt.colorbar()
for i in range(len(chosen_commands)):
    for j in range(len(chosen_commands)):
        color = 'white' if cm[i, j] > cm.max() / 2 else 'black'
        plt.text(j, i, cm[i, j], ha='center', va='center', color=color)
plt.tight_layout()
plt.show()




# Evaluating Inference time on test set whcih is important for us becasue we need fast response for our snake game
single_sample = next(iter(test_ds_batched))[0][0:1]
for _ in range(10):
    model(single_sample, training=False)
times = []
for _ in range(100):
    start = time.time()
    model(single_sample, training=False)
    end = time.time()
    times.append((end - start) * 1000)
print(f"\nInference Time:")
print(f"  Average: {np.mean(times):.2f}ms")
print(f"  Min:     {np.min(times):.2f}ms")
print(f"  Max:     {np.max(times):.2f}ms")
print(f"  Std:     {np.std(times):.2f}ms")
print(f"\nAudio clip duration: 1000ms")
print(f"Real time factor:    {np.mean(times)/1000:.3f}x")
